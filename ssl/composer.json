{
    "name": "ascio/whmcs-ssl-module",
    "description": "Ascio SSL Module for WHMCS",
    "type": "whmcs-module",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-soap": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "ascio\\whmcs\\ssl\\": "lib/",
            "ascio\\v3\\": "v3/service/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ascio\\Ssl\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
