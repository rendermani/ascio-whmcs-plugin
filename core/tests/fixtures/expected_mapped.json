{
    "_description": "Expected v3 to v2 mapped responses - what RequestV3 should return to maintain compatibility",
    "_purpose": "These responses show how v3 API responses should be mapped to maintain v2 API compatibility in the WHMCS module",

    "CreateOrder_Success": {
        "_comment": "v3 Order response mapped to match v2 expectations",
        "Order": {
            "OrderId": "ORD123456",
            "Type": "Register_Domain",
            "Status": "Pending",
            "TransactionComment": "{\"application\":\"WHMCS\",\"domainId\":12345,\"userId\":100,\"objectType\":\"Domain\"}",
            "Domain": {
                "DomainName": "example.com",
                "DomainHandle": "DOM789",
                "RegPeriod": 1,
                "Status": "ACTIVE",
                "ExpDate": "2025-12-31T00:00:00",
                "CreDate": "2024-12-31T00:00:00"
            }
        },
        "_mapping_notes": [
            "RequestV3::sendRequest() returns raw v3 response",
            "Key is 'Order' (PascalCase) - consumers must handle this",
            "Domain object structure is compatible"
        ]
    },

    "CreateOrder_Error": {
        "_comment": "v3 error response mapped to v2-compatible error array",
        "error": "Invalid email address, \r\nPhone number format incorrect",
        "_mapping_notes": [
            "v3: Errors->string array joined with ', \\r\\n'",
            "v2: Values->string array joined with ', \\r\\n'",
            "Both return ['error' => 'message'] format",
            "Tools::cleanString() applied to message"
        ]
    },

    "GetOrder": {
        "_comment": "GetOrder response - note Order key is PascalCase",
        "Order": {
            "OrderId": "ORD123456",
            "Type": "Register_Domain",
            "Status": "Completed",
            "Domain": {
                "DomainName": "example.com",
                "DomainHandle": "DOM789",
                "Status": "ACTIVE"
            }
        },
        "_mapping_notes": [
            "v3 uses Order (PascalCase)",
            "v2 uses order (lowercase)",
            "RequestV3 returns v3 format - callers must use Order"
        ]
    },

    "GetDomain": {
        "_comment": "GetDomain response - Domain object is returned directly",
        "DomainName": "example.com",
        "DomainHandle": "DOM789",
        "RegPeriod": 1,
        "AuthInfo": "EPP123456",
        "Status": "ACTIVE,LOCK",
        "ExpDate": "2025-12-31T00:00:00",
        "CreDate": "2024-12-31T00:00:00",
        "TransferLock": "Lock",
        "Registrant": {
            "Name": "John Doe",
            "OrgName": "Example Corp",
            "Email": "john@example.com"
        },
        "NameServers": {
            "NameServer1": {"HostName": "ns1.example.com"},
            "NameServer2": {"HostName": "ns2.example.com"}
        },
        "_mapping_notes": [
            "RequestV3::getDomain() extracts Domain from response",
            "Returns $result->Domain directly",
            "Compatible with v2 - same domain object structure"
        ]
    },

    "SearchDomain": {
        "_comment": "SearchDomain returns domain object with domainId added",
        "DomainName": "example.com",
        "DomainHandle": "DOM789",
        "Status": "ACTIVE",
        "domainId": 12345,
        "_mapping_notes": [
            "RequestV3::searchDomain() extracts Domain from Domains->Domain",
            "Adds domainId from params to domain object",
            "Calls setDomainStatus() and setHandle()",
            "Caches result in DomainCacheV3"
        ]
    },

    "SearchDomain_NotFound": {
        "_comment": "Domain not found error",
        "error": "Domain not found",
        "_mapping_notes": [
            "Both v2 and v3 return (object)['error' => 'Domain not found']"
        ]
    },

    "AvailabilityInfo": {
        "_comment": "Availability check - same structure in both versions",
        "ResultCode": 200,
        "ResultMessage": "Success",
        "DomainName": "available-domain.com",
        "DomainNameAvailable": true,
        "QualityType": "Live",
        "_mapping_notes": [
            "Structure is identical between v2 and v3",
            "No mapping required"
        ]
    },

    "Poll": {
        "_comment": "Poll response - method name different but structure mapped",
        "ResultCode": 200,
        "QueueMessage": {
            "MessageId": 12345,
            "MsgId": 12345,
            "OrderId": "ORD123456",
            "OrderStatus": "Completed",
            "ObjectName": "example.com",
            "DomainName": "example.com"
        },
        "_mapping_notes": [
            "v3: PollQueue with QueueMessage",
            "v2: PollMessage with item",
            "v3 response includes both MessageId and MsgId for compatibility",
            "v3 includes both ObjectName and DomainName for compatibility"
        ]
    },

    "Poll_Empty": {
        "_comment": "Empty queue response",
        "ResultCode": 201,
        "QueueMessage": null,
        "_mapping_notes": [
            "ResultCode 201 indicates empty queue in both versions"
        ]
    },

    "GetQueueMessage": {
        "_comment": "Queue message details",
        "ResultCode": 200,
        "DomainName": "example.com",
        "ObjectName": "example.com",
        "Message": "Registration completed successfully",
        "_mapping_notes": [
            "v3: GetQueueMessage returns Message object",
            "v2: GetMessageQueue returns item object",
            "Key fields are accessible in both"
        ]
    },

    "AckQueueMessage": {
        "_comment": "Acknowledge message - no return value needed",
        "ResultCode": 200,
        "_mapping_notes": [
            "v3: AckQueueMessage",
            "v2: AckMessage",
            "RequestV3::ack() wraps ackQueueMessage() for compatibility"
        ]
    },

    "Error_Auth": {
        "_comment": "Authentication error - both versions return error array",
        "error": "Login failed: invalid account or password",
        "_mapping_notes": [
            "v3 returns immediate error (no session retry)",
            "v2 clears session cache and may retry",
            "Final error format is compatible"
        ]
    },

    "Error_Validation": {
        "_comment": "Validation errors joined into single message",
        "error": "Error 1, \r\nError 2, \r\nError 3",
        "_mapping_notes": [
            "Multiple errors joined with ', \\r\\n'",
            "Tools::cleanString() applied",
            "Same format in both versions"
        ]
    },

    "Error_Temporary": {
        "_comment": "Temporary server error",
        "error": "Temporary error. Please try later or contact your support.",
        "_mapping_notes": [
            "ResultCode 554 triggers this message in both versions"
        ]
    },

    "_compatibility_summary": {
        "fully_compatible": [
            "Domain object structure",
            "Contact/Registrant object structure",
            "NameServers object structure",
            "Error return format ['error' => 'message']",
            "Result codes (200, 201, 400, 401, etc)",
            "AvailabilityInfo response",
            "Date formats (ISO 8601)"
        ],
        "key_case_changes": {
            "order": "Order",
            "domain": "Domain",
            "domains": "Domains",
            "item": "QueueMessage/Message"
        },
        "method_renames": {
            "PollMessage": "PollQueue",
            "GetMessageQueue": "GetQueueMessage",
            "AckMessage": "AckQueueMessage"
        },
        "removed_in_v3": [
            "sessionId parameter",
            "LogIn method",
            "Session caching"
        ],
        "migration_impact": {
            "low_risk": [
                "Domain/Contact/Nameserver structures",
                "Error handling",
                "Date parsing"
            ],
            "medium_risk": [
                "Polling method changes",
                "Response key case changes"
            ],
            "requires_code_update": [
                "Session management removal",
                "Accessing Order vs order key"
            ]
        }
    }
}
