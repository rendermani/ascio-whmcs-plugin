    "description": "Ascio Core Library for WHMCS Modules",
    "type": "library",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ascio\\Core\\": "lib/"
        }
    },
    "autoload-dev": {
